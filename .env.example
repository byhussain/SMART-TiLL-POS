APP_NAME="SMART TiLL"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
DB_BUSY_TIMEOUT=60000
DB_JOURNAL_MODE=WAL
DB_SYNCHRONOUS=NORMAL

# Kill switch for the fast snapshot bootstrap. Defaults true. Set to false
# to disable the snapshot path remotely without a re-release if it ever
# misbehaves in production — the device falls back to the legacy ndjson path.
CLOUD_BOOTSTRAP_USE_SNAPSHOT=true

# Wall-clock cap (seconds) on the synchronous push that runs when the user
# switches stores. If the server is slow or offline, the switch proceeds
# anyway after this budget; the leaving store's pending rows simply stay
# pending and ship on the next online visit.
CLOUD_SWITCH_PUSH_TIMEOUT=15

SESSION_DRIVER=database
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Background driver runs jobs in a forked PHP process and does NOT use the
# database for queue storage. Required when DB_CONNECTION=sqlite — the
# database queue driver opens its own transaction in pop() and races with
# our own DB::transaction usage, throwing "cannot start a transaction
# within a transaction" mid-poll.
QUEUE_CONNECTION=background

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

POS_CLOUD_BASE_URL=https://smart-till.app

NATIVEPHP_APP_ID=app.smart-till
NATIVEPHP_APP_AUTHOR="SMART DADDY"
NATIVEPHP_APP_COPYRIGHT="Copyright (c) 2026 Smart Till. All rights reserved."
NATIVEPHP_APP_DESCRIPTION="A point of sale system built with Laravel and NativePHP."
NATIVEPHP_APP_WEBSITE="https://smart-till.app"
NATIVEPHP_UPDATER_ENABLED=false
NATIVEPHP_UPDATER_PROVIDER=github

GITHUB_REPO=SMART-TiLL-POS
GITHUB_OWNER=byhussain
GITHUB_RELEASE_TYPE=release
GITHUB_V_PREFIXED_TAG_NAME=true
GITHUB_PRIVATE=false
GITHUB_CHANNEL=latest
GITHUB_TOKEN=
